{
  "name": "@c2paviewer/c2pa-mcp",
  "version": "0.1.0",
  "description": "An open-source MCP server that verifies C2PA content credentials and returns LLM-ready provenance verdicts. Built by c2paviewer.com.",
  "type": "module",
  "bin": {
    "c2pa-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE-MIT",
    "LICENSE-APACHE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "npm run build && node --test",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "c2pa",
    "mcp",
    "model-context-protocol",
    "content-credentials",
    "provenance",
    "ai-detection",
    "content-authenticity",
    "deepfake"
  ],
  "author": "c2paviewer.com",
  "license": "MIT OR Apache-2.0",
  "dependencies": {
    "@contentauth/c2pa-node": "^0.5.5",
    "@contentauth/c2pa-types": "^0.6.0",
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.5.0"
  }
}
